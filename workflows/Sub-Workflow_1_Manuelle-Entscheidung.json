      "parameters": {
        "jsCode": "const normalisiert = $('Normalisieren + Filter').first().json;\nconst dbDaten = $input.first().json;\n\n// Status-Check: nur weiter wenn noch in manueller Pruefung\nif (dbDaten.status_ !== 'manuell_pruefen') {\n  return [];\n}\n\nreturn [{\n  json: {\n    id: dbDaten.id,\n    name: dbDaten.name,\n    email: dbDaten.email,\n    email_from: dbDaten.email,\n    plz_wohnort: dbDaten.plz_wohnort,\n    manuelle_entscheidung: normalisiert.manuelle_entscheidung,\n    ist_telegram: true,\n    telegram_chat_id: normalisiert.telegram_chat_id,\n    telegram_message_id: normalisiert.telegram_message_id,\n    telegram_callback_query_id: normalisiert.telegram_callback_query_id\n  }\n}];"
