    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet id, entscheidung, aktuellerStatus, name, email, plz_wohnort;\nlet istTelegram = false;\n\nif (input.body?.data?.rows) {\n  // Format A: NocoDB-Webhook\n  const row = input.body.data.rows[0];\n  id = row.Id;\n  entscheidung = row.manuelle_entscheidung;\n  aktuellerStatus = row.status;\n  name = row.name;\n  email = row.email;\n  plz_wohnort = row.plz_wohnort;\n} else if (input.callback_query) {\n  // Format B: Telegram Inline-Button Callback\n  istTelegram = true;\n  const callbackData = (input.callback_query.data || '').replace(/^=/, ''); // z.B. \"einladen:2\"\n  const [aktion, idStr] = callbackData.split(':');\n  entscheidung = aktion;\n  id = parseInt(idStr, 10);\n} else {\n  return [];\n}\n\nconst gueltigeEntscheidungen = ['einladen', 'absagen'];\nif (!gueltigeEntscheidungen.includes(entscheidung)) {\n  return [];\n}\n\nif (!istTelegram && aktuellerStatus !== 'manuell_pruefen') {\n  return [];\n}\n\nreturn [{\n  json: {\n    id,\n    name: name || null,\n    email: email || null,\n    email_from: email || null,\n    plz_wohnort: plz_wohnort || null,\n    manuelle_entscheidung: entscheidung,\n    ist_telegram: istTelegram,\n    telegram_chat_id: istTelegram ? input.callback_query.message.chat.id : null,\n    telegram_message_id: istTelegram ? input.callback_query.message.message_id : null,\n    telegram_callback_query_id: istTelegram ? input.callback_query.id : null\n  }\n}];"
      },
