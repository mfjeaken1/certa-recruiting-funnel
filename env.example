# Certa Recruiting Funnel - Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Werte ein

# Docker Compose Projektname (wird auch als Subdomain genutzt)
COMPOSE_PROJECT_NAME=n8n-certa

# Traefik Host (deine Domain oder IP)
TRAEFIK_HOST=example.com

# Zeitzone
TZ=Europe/Berlin

# PostgreSQL Passwort (mind. 20 Zeichen, zufällig generiert)
POSTGRES_PASSWORD=DEIN_SICHERES_PASSWORT_HIER
